    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@types/bcrypt": "^5.0.0",
    "@types/cookie-parser": "^1.4.3",
    "@types/express": "^4.17.17",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.3.1",
    "@types/passport-jwt": "^3.0.9",
    "@types/sanitize-html": "^2.16.1",
    "@types/uuid": "^9.0.2",
    "prisma": "^5.0.0",
    "source-map-support": "^0.5.21",
