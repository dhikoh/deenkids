generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPERADMIN
  ADMIN
  AUTHOR
}

model User {
  id               String                 @id @default(uuid())
  email            String                 @unique
  passwordHash     String
  name             String
  role             Role                   @default(AUTHOR)
  phone            String?
  bio              String?
  bankName         String?
  bankAccount      String?
  bankHolder       String?
  points           Int                    @default(0)
  locale           String                 @default("id")
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  refreshTokens    RefreshToken[]
  contentItems     ContentItem[]
  reviewHistory    ReviewHistory[]
  authorStats      AuthorStat?
  notifications    InternalNotification[] @relation("NotifiedUser")
  sentNotification InternalNotification[] @relation("NotifierUser")
  rewards          Reward[]
  pointLedger      PointLedger[]
  withdrawals      WithdrawalRequest[]
  conversationsA   Conversation[]         @relation("ConversationA")
  conversationsB   Conversation[]         @relation("ConversationB")
  sentMessages     Message[]
  loginHistory     LoginHistory[]
  socialAccounts   SocialAccount[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

enum NodeType {
  CATEGORY
  MODULE
  TOPIC
}

model ContentNode {
  id          String        @id @default(uuid())
  slug        String        @unique
  title       String
  description String?
  type        NodeType
  parentId    String?
  parent      ContentNode?  @relation("NodeHierarchy", fields: [parentId], references: [id])
  children    ContentNode[] @relation("NodeHierarchy")
  ageGroups   String[] // e.g., ["3-5", "5-7", "7-10"]
  order       Int           @default(0)
  icon        String?
  group       String        @default("PEMBELAJARAN") // 'PEMBELAJARAN' | 'KISAH'
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  contents    ContentItem[]

  @@index([parentId])
}

enum ContentStatus {
  DRAFT
  REVIEW
  REVISION
  PUBLISHED
  ARCHIVED
}

enum ContentType {
  QNA
  ARTICLE
  PEMBELAJARAN
  KISAH
}

model ContentItem {
  id                 String             @id @default(uuid())
  slug               String             @unique
  title              String
  description        String?
  thumbnailUrl       String? // URL gambar thumbnail untuk card & OG image
  type               ContentType
  status             ContentStatus      @default(DRAFT)
  nodeId             String?
  node               ContentNode?       @relation(fields: [nodeId], references: [id])
  authorId           String
  author             User               @relation(fields: [authorId], references: [id])
  displayAuthorName  String? // SuperAdmin alias — if set, shown instead of author.name
  ageGroups          String[] // e.g., ["3-5", "5-7"]
  metaTitle          String?
  metaDesc           String?
  viewCount          Int                @default(0)
  likeCount          Int                @default(0)
  bookmarkCount      Int                @default(0)
  shareCount         Int                @default(0)
  avgRating          Float              @default(0.0)
  ratingCount        Int                @default(0)
  publishedAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  qnaDetail          QnaDetail?
  articleDetail      ArticleDetail?
  tags               ContentItemTag[]
  likes              ContentLike[]
  bookmarks          ContentBookmark[]
  ratings            ContentRating[]
  views              ContentView[]
  reviewHistory      ReviewHistory[]
  aiCheckResults     AiCheckResult[]
  relatedFrom        RelatedContent[]   @relation("SourceContent")
  relatedTo          RelatedContent[]   @relation("TargetContent")
  enableAudio        Boolean            @default(false)
  audioTitle         Boolean            @default(true)
  audioDescription   Boolean            @default(true)
  audioUrl           String? // URL file MP3 narasi yang di-upload (hasil TTS generate)
  pov                String? // 'ORTU' | 'ANAK' — Point of view, hanya untuk ARTICLE type
  openingText        String? // Mukadimah/pembukaan: teks salam + pengantar
  closingText        String? // Penutupan: teks penutup + salam
  openingAudio       Boolean            @default(true) // Enable audio for opening
  closingAudio       Boolean            @default(true) // Enable audio for closing
  deletedAt          DateTime? // Soft delete timestamp, null = active
  previousStatus     String? // Status before deletion, for trash UI display
  socialThumbnailUrl String? // Thumbnail 1:1 untuk IG/FB post
  socialPublishLogs  SocialPublishLog[]

  @@index([authorId, status])
  @@index([status, type])
  @@index([publishedAt])
  @@index([deletedAt])
  @@index([type, pov])
}

model QnaDetail {
  id                      String      @id @default(uuid())
  contentId               String      @unique
  content                 ContentItem @relation(fields: [contentId], references: [id], onDelete: Cascade)
  question                String
  answerQuick             String
  answerQuickReferenceUrl String? // Reference URL for the quick answer
  blocks                  Json        @default("[]") // unified block array (paragraph, dialog, dalil, analogy, tip, image, video)
  // Legacy fields — kept for dual-phase migration safety, will be removed after Phase 2 cleanup
  dialogBlocks            Json        @default("[]")
  dalilBlocks             Json        @default("[]")
  analogyBlocks           Json        @default("[]")
  tipsBlocks              Json        @default("[]")
}

model ArticleDetail {
  id        String      @id @default(uuid())
  contentId String      @unique
  content   ContentItem @relation(fields: [contentId], references: [id], onDelete: Cascade)
  coverUrl  String?
  blocks    Json // article content blocks
}

model ContentTag {
  id         String           @id @default(uuid())
  name       String           @unique
  slug       String           @unique
  usageCount Int              @default(0)
  createdAt  DateTime         @default(now())
  items      ContentItemTag[]
}

model ContentItemTag {
  id        String      @id @default(uuid())
  contentId String
  tagId     String
  content   ContentItem @relation(fields: [contentId], references: [id], onDelete: Cascade)
  tag       ContentTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([contentId, tagId])
}

model RelatedContent {
  id        String      @id @default(uuid())
  sourceId  String
  targetId  String
  source    ContentItem @relation("SourceContent", fields: [sourceId], references: [id], onDelete: Cascade)
  target    ContentItem @relation("TargetContent", fields: [targetId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([sourceId, targetId])
}

model ContentLike {
  id        String      @id @default(uuid())
  contentId String
  content   ContentItem @relation(fields: [contentId], references: [id], onDelete: Cascade)
  userHash  String
  createdAt DateTime    @default(now())

  @@unique([contentId, userHash])
}

model ContentBookmark {
  id        String      @id @default(uuid())
  contentId String
  content   ContentItem @relation(fields: [contentId], references: [id], onDelete: Cascade)
  userHash  String
  createdAt DateTime    @default(now())

  @@unique([contentId, userHash])
}

model ContentRating {
  id        String      @id @default(uuid())
  contentId String
  content   ContentItem @relation(fields: [contentId], references: [id], onDelete: Cascade)
  userHash  String
  rating    Int // 1-5
  createdAt DateTime    @default(now())

  @@unique([contentId, userHash])
}

model ContentView {
  id        String      @id @default(uuid())
  contentId String
  content   ContentItem @relation(fields: [contentId], references: [id], onDelete: Cascade)
  userHash  String
  duration  Int         @default(0)
  viewedAt  DateTime    @default(now())

  @@index([contentId, userHash])
  @@index([viewedAt])
}

enum ReviewAction {
  APPROVED
  REJECTED
  REVISION_REQUESTED
}

model ReviewHistory {
  id          String       @id @default(uuid())
  contentId   String
  content     ContentItem  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  reviewerId  String
  reviewer    User         @relation(fields: [reviewerId], references: [id], onDelete: Cascade)
  action      ReviewAction
  aiAssisted  Boolean      @default(false)
  aiScore     Int?
  manualScore Int?
  notes       String?
  createdAt   DateTime     @default(now())

  @@index([contentId])
}

model AiCheckResult {
  id          String      @id @default(uuid())
  contentId   String
  content     ContentItem @relation(fields: [contentId], references: [id], onDelete: Cascade)
  score       Int
  breakdown   Json
  issues      Json
  suggestions Json
  provider    String      @default("openai")
  checkedAt   DateTime    @default(now())
}

enum NotificationType {
  REVIEW_REQUEST
  CONTENT_APPROVED
  CONTENT_REJECTED
  REVISION_NEEDED
  DONATION_RECEIVED
  FEEDBACK_RECEIVED
  POINTS_EARNED
  WITHDRAWAL_REQUESTED
  WITHDRAWAL_PROCESSED
  NEW_MESSAGE
  SYSTEM_ALERT
}

model InternalNotification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation("NotifiedUser", fields: [userId], references: [id], onDelete: Cascade)
  actorId   String?
  actor     User?            @relation("NotifierUser", fields: [actorId], references: [id], onDelete: SetNull)
  type      NotificationType
  title     String
  message   String
  linkUrl   String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
  @@index([createdAt])
}

model Setting {
  id        String   @id @default(uuid())
  group     String   @default("general")
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model AuthorStat {
  id               String   @id @default(uuid())
  authorId         String   @unique
  author           User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  totalPublished   Int      @default(0)
  totalViews       Int      @default(0)
  totalLikes       Int      @default(0)
  avgContentRating Float    @default(0.0)
  updatedAt        DateTime @updatedAt
}

model Reward {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeName   String
  description String?
  issuedAt    DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  details    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

model DonationSubmission {
  id         String    @id @default(uuid())
  name       String
  amount     Int // Rupiah
  method     String // "bank" | "qris" | "saweria"
  message    String?
  proofUrl   String? // file path to proof image
  isVerified Boolean   @default(false)
  verifiedAt DateTime?
  verifiedBy String?
  createdAt  DateTime  @default(now())
}

enum FeedbackType {
  KRITIK
  SARAN
  PERTANYAAN
}

model FeedbackSubmission {
  id        String       @id @default(uuid())
  name      String
  email     String?
  type      FeedbackType
  message   String
  isRead    Boolean      @default(false)
  createdAt DateTime     @default(now())
}

enum PointType {
  EARNED
  BONUS
  WITHDRAWAL
  DEDUCTION
}

model PointLedger {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int
  type      PointType
  reason    String
  contentId String?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([contentId, type])
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  DISBURSED
}

model WithdrawalRequest {
  id           String           @id @default(uuid())
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  pointsAmount Int
  rupiahAmount Int
  bankName     String
  bankAccount  String
  bankHolder   String
  status       WithdrawalStatus @default(PENDING)
  processedBy  String?
  processedAt  DateTime?
  notes        String?
  createdAt    DateTime         @default(now())

  @@index([userId, status])
  @@index([createdAt])
}

model Conversation {
  id             String    @id @default(uuid())
  participantAId String
  participantBId String
  participantA   User      @relation("ConversationA", fields: [participantAId], references: [id])
  participantB   User      @relation("ConversationB", fields: [participantBId], references: [id])
  lastMessageAt  DateTime  @default(now())
  messages       Message[]
  createdAt      DateTime  @default(now())

  @@unique([participantAId, participantBId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])
  text           String?
  attachmentUrl  String?
  attachmentType String?
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([conversationId, isRead])
}

model SponsorBanner {
  id          String    @id @default(uuid())
  title       String
  imageUrl    String
  linkUrl     String?
  isActive    Boolean   @default(true)
  startDate   DateTime?
  endDate     DateTime?
  priority    Int       @default(0)
  impressions Int       @default(0)
  clicks      Int       @default(0)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ErrorReport {
  id          String   @id @default(uuid())
  fingerprint String   @unique // hash of message+source — prevents duplicates
  message     String
  stack       String?
  source      String? // URL where error occurred
  userAgent   String?
  userId      String?
  category    String   @default("JS_ERROR") // JS_ERROR | REACT_CRASH | API_ERROR | PROMISE_REJECT
  httpStatus  Int? // HTTP status code for API_ERROR (400, 500, etc.)
  occurrences Int      @default(1)
  isResolved  Boolean  @default(false)
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isResolved, lastSeenAt])
  @@index([lastSeenAt])
  @@index([category])
}

model LoginHistory {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ip        String?
  userAgent String?
  loginAt   DateTime @default(now())

  @@index([userId, loginAt])
}

model PageContent {
  id        String   @id @default(uuid())
  slug      String   @unique
  title     String
  content   Json
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model SocialAccount {
  id                String             @id @default(uuid())
  userId            String
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform          String             @default("META") // 'META' = FB + IG, 'YOUTUBE' = YouTube
  pageName          String
  pageId            String?            @unique // Meta page ID (null for YouTube)
  igAccountId       String?
  igUsername        String?
  pageAccessToken   String // Encrypted — Meta page token or YouTube refresh token
  profilePictureUrl String?
  defaultHashtags   String?            @default("#adably #edukasiislami #parentingislami")
  captionTemplate   String?
  isActive          Boolean            @default(true)
  connectedAt       DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  publishLogs       SocialPublishLog[]

  // YouTube-specific fields
  ytChannelId       String?            @unique // YouTube channel ID
  ytChannelTitle    String?            // YouTube channel display name

  @@index([userId])
}

model SocialPublishLog {
  id              String        @id @default(uuid())
  contentId       String
  content         ContentItem   @relation(fields: [contentId], references: [id])
  socialAccountId String
  socialAccount   SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  platform        String // 'INSTAGRAM' | 'FACEBOOK'
  postId          String?
  postUrl         String?
  caption         String
  imageUrl        String
  status          String        @default("SCHEDULED") // SCHEDULED | PUBLISHING | PUBLISHED | FAILED | CANCELLED
  scheduledAt     DateTime?
  publishedAt     DateTime?
  error           String?
  retryCount      Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status, scheduledAt])
  @@index([contentId])
  @@index([socialAccountId])
}
